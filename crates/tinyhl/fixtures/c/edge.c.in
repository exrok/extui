void ops(int a, int b) {
    a <<= 1;
    b >>= 2;
    a += b; a -= b; a *= b; a /= b; a %= b;
    a &= b; a |= b; a ^= b;
    int c = a == b;
    int d = a != b;
    int e = a && b;
    int f = a || b;
    (void)(a++); (void)(++a);
    (void)(b--); (void)(--b);
}

void variadic(int n, ...);

int digraphs(void) <%
    int arr<:3:> = <% 1, 2, 3 %>;
    return arr<:0:> + arr<:1:> + arr<:2:>;
%>

