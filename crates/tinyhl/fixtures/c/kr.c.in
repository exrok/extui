/*
 * wc.c — a minimal K&R-style line/word/byte counter.
 *
 * Intended as a realistic multi-chunk fixture for the incremental lexer.
 * No dependencies beyond libc; mirrors the structure of the original in
 * The C Programming Language.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>

#define IN  1
#define OUT 0

#define FLAG_LINES 0x01
#define FLAG_WORDS 0x02
#define FLAG_BYTES 0x04
#define FLAG_ALL   (FLAG_LINES | FLAG_WORDS | FLAG_BYTES)

struct counts {
    long lines;
    long words;
    long bytes;
};

static int is_space(int c) {
    return c == ' ' || c == '\t' || c == '\n' || c == '\r' || c == '\v' || c == '\f';
}

static void counts_zero(struct counts *c) {
    c->lines = 0;
    c->words = 0;
    c->bytes = 0;
}

static void counts_add(struct counts *dst, const struct counts *src) {
    dst->lines += src->lines;
    dst->words += src->words;
    dst->bytes += src->bytes;
}

/*
 * Count lines, words and bytes on `fp`, storing the result in `out`.
 * Returns 0 on success, -1 on read error (errno set).
 */
static int count(FILE *fp, struct counts *out) {
    int c;
    int state = OUT;
    counts_zero(out);
    while ((c = getc(fp)) != EOF) {
        out->bytes++;
        if (c == '\n') {
            out->lines++;
        }
        if (is_space(c)) {
            state = OUT;
        } else if (state == OUT) {
            state = IN;
            out->words++;
        }
    }
    if (ferror(fp)) {
        return -1;
    }
    return 0;
}

static void emit(const char *name, const struct counts *c, unsigned flags) {
    if (flags & FLAG_LINES) printf(" %7ld", c->lines);
    if (flags & FLAG_WORDS) printf(" %7ld", c->words);
    if (flags & FLAG_BYTES) printf(" %7ld", c->bytes);
    if (name != NULL) printf(" %s", name);
    printf("\n");
}

static unsigned parse_flags(int argc, char **argv, int *first) {
    unsigned f = 0;
    int i = 1;
    while (i < argc && argv[i][0] == '-' && argv[i][1] != '\0') {
        const char *p = argv[i] + 1;
        if (p[0] == '-' && p[1] == '\0') { i++; break; }
        while (*p) {
            switch (*p) {
                case 'l': f |= FLAG_LINES; break;
                case 'w': f |= FLAG_WORDS; break;
                case 'c': f |= FLAG_BYTES; break;
                default:
                    fprintf(stderr, "wc: unknown flag -%c\n", *p);
                    exit(2);
            }
            p++;
        }
        i++;
    }
    if (f == 0) f = FLAG_ALL;
    *first = i;
    return f;
}

int main(int argc, char **argv) {
    int first = 1;
    unsigned flags = parse_flags(argc, argv, &first);
    struct counts total;
    counts_zero(&total);

    if (first >= argc) {
        struct counts c;
        if (count(stdin, &c) < 0) {
            perror("wc: stdin");
            return 1;
        }
        emit(NULL, &c, flags);
        return 0;
    }

    int n_files = argc - first;
    int status = 0;
    for (int i = first; i < argc; i++) {
        FILE *fp = fopen(argv[i], "rb");
        if (fp == NULL) {
            fprintf(stderr, "wc: %s: %s\n", argv[i], strerror(errno));
            status = 1;
            continue;
        }
        struct counts c;
        if (count(fp, &c) < 0) {
            fprintf(stderr, "wc: %s: %s\n", argv[i], strerror(errno));
            fclose(fp);
            status = 1;
            continue;
        }
        fclose(fp);
        emit(argv[i], &c, flags);
        counts_add(&total, &c);
    }

    if (n_files > 1) {
        emit("total", &total, flags);
    }
    return status;
}
