---
apiVersion: v1
kind: ConfigMap
metadata:
  name: tinyhl-demo
  labels: { app: tinyhl, env: production }
data:
  enabled: true
  retries: 3
  ratio: -0.5
  empty: null
  path: /var/lib/tinyhl
  quoted: "line\nvalue"
  single: 'it''s ok'
  literal: |
    first line
    second line
  folded: >
    first line
    second line
refs:
  - &base item
  - *base
  - !custom tagged
flow: [one, two, {nested: false}]
...
# trailing comment
