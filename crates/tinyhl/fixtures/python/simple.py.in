#!/usr/bin/env python3
"""Module docstring spanning
multiple lines with a 'quote' inside."""

import os
from collections import OrderedDict as OD


GREETING = "hello, world\n"
RAW = r"raw\path\to"
BYTES = b"\x00\x01"
TEMPLATE = f"value = {GREETING!r}"
PI = 3.14159
HEX = 0xDEAD_BEEF
BIN = 0b1010
OCTAL = 0o755
BIG = 1_000_000
COMPLEX = 1.5j
ELLIPSIS = ...


@staticmethod
def compute(values: list[int], *, scale: float = 1.0) -> float:
    # Floor division, power, walrus, and matrix-style operators.
    total = 0
    for v in values:
        total += v // 2 ** 1
    if (n := len(values)) > 0:
        total /= n
    return total * scale


class Point:
    '''A 2-D point.'''

    def __init__(self, x=0, y=0):
        self.x = x
        self.y = y

    def norm(self) -> float:
        return (self.x * self.x + self.y * self.y) ** 0.5


def main():
    pts = {"a": Point(1, 2), "b": Point(3, 4)}
    data = [p.norm() for p in pts.values() if p is not None]
    result = OD()
    while data and not result:
        result["max"] = max(data)
        del data[-1]
    print(result, GREETING, café := "accent")


if __name__ == "__main__":
    main()
